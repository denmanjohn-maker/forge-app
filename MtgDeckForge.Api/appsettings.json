{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MongoDb": {
    "ConnectionString": "mongodb://mongodb:27017",
    "DatabaseName": "mtgdeckforge",
    "DecksCollectionName": "decks",
    "UsersCollectionName": "users",
    "GroupsCollectionName": "groups"
  },
  "JwtSettings": {
    "Secret": "MtgDeckForge-SuperSecret-Key-Change-In-Production-Min32Chars!",
    "Issuer": "MtgDeckForge",
    "Audience": "MtgDeckForge",
    "ExpirationMinutes": 1440
  },
  "ClaudeApi": {
    "ApiKey": "${ANTHROPIC_API_KEY}",
    "Model": "claude-sonnet-4-20250514",
    "MaxTokens": 8192
  },
  "SqlStorage": {
    "ConnectionString": "Server=(localdb)\\MSSQLLocalDB;Database=MtgDeckForgeLocal;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "MtgJson": {
    "PricesUrl": "https://mtgjson.com/api/v5/AllPricesToday.json",
    "PrintingsUrl": "https://mtgjson.com/api/v5/AllPrintings.json"
  },
  "Cors": {
    "AllowedOrigins": ""
  },
  "AdminUsername": "admin",
  "AdminDisplayName": "Administrator",
  "AdminPassword": ""
