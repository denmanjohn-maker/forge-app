@page
@model MtgDeckForge.Api.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
}
<h2>Login</h2>
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="card">@Model.ErrorMessage</div>
}
<form method="post">
    <div><label>Username</label><br/><input asp-for="Input.Username" /></div>
    <div><label>Password</label><br/><input asp-for="Input.Password" type="password" /></div>
    <button type="submit">Sign In</button>
</form>
