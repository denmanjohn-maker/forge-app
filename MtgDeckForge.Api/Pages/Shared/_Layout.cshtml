<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MTG Deck Forge</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 0; background: #111; color: #eee; }
        nav { background: #1b1b1b; padding: 12px 18px; display:flex; gap:14px; align-items:center; }
        a { color: #d4b36d; text-decoration: none; }
        main { padding: 18px; max-width: 1100px; margin: 0 auto; }
        input, select, textarea, button { padding: 8px; margin: 4px 0; }
        .card { background:#1b1b1b; border:1px solid #333; padding:12px; margin:10px 0; border-radius:8px; }
        .row { display:flex; gap:8px; flex-wrap:wrap; }
        table { width: 100%; border-collapse: collapse; }
        th, td { border-bottom: 1px solid #333; padding: 8px; text-align: left; }
    </style>
</head>
<body>
<nav>
    <a asp-page="/Index">Home</a>
    <a asp-page="/Decks/Index">Decks</a>
    <a asp-page="/Decks/Generate">Generate</a>
    <span style="margin-left:auto; opacity:0.5; font-size:0.8em;">@(Environment.GetEnvironmentVariable("BUILD_VERSION") is string v && v != "dev" ? "v" + v : "")</span>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <span>Signed in as @User.Identity.Name</span>
        <a asp-page="/Account/Logout">Logout</a>
    }
    else
    {
        <a asp-page="/Account/Login">Login</a>
    }
</nav>
<main>
    @RenderBody()
</main>
</body>
</html>
