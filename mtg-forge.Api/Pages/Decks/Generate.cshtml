@page
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@model MtgForge.Api.Pages.Decks.GenerateModel
@{
    ViewData["Title"] = "Generate";
}
<h2>Generate Deck</h2>
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="card">@Model.ErrorMessage</div>
}
<form method="post">
    <div><label>Colors (comma separated W,U,B,R,G)</label><br/><input asp-for="Input.ColorsCsv" /></div>
    <div><label>Format</label><br/><input asp-for="Input.Format" /></div>
    <div><label>Power Level</label><br/><input asp-for="Input.PowerLevel" /></div>
    <div><label>Budget</label><br/><input asp-for="Input.BudgetRange" /></div>
    <div><label>Preferred Strategy</label><br/><input asp-for="Input.PreferredStrategy" /></div>
    <div><label>Preferred Commander</label><br/><input asp-for="Input.PreferredCommander" /></div>
    <div><label>Additional Notes</label><br/><textarea asp-for="Input.AdditionalNotes"></textarea></div>
    <button type="submit">Generate</button>
</form>
@if (Model.CreatedDeckId is not null)
{
    <div class="card">Deck created. <a asp-page="/Decks/Details" asp-route-id="@Model.CreatedDeckId">Open deck</a></div>
}
